<h1 class="mb-4"><%= @place["name"] %></h1>

<% if @current_user %>
  <div class="d-flex justify-content-between align-items-center mb-3">
    <h2 class="mb-0">My Entries</h2>
    <a href="/entries/new?place_id=<%= @place["id"] %>" class="btn btn-primary">New Entry</a>
  </div>

  <div class="row">
    <% for entry in @entries %>
      <div class="col-12 col-md-6 col-lg-4 mb-4">
        <div class="card h-100">
          <% if entry.uploaded_image.attached? %>
            <img src="<%= url_for(entry.uploaded_image) %>" class="card-img-top img-fluid">
          <% end %>

          <div class="card-body">
            <h5 class="card-title"><%= entry["title"] %></h5>
            <p class="text-muted"><%= entry["occurred_on"] %></p>
            <p><%= entry["description"] %></p>
          </div>
        </div>
      </div>
    <% end %>
  </div>
<% end %>

<p>
  <a href="/places" class="btn btn-secondary">Back to All Places</a>
</p>